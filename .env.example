# Kopiere diese Datei zu ".env" und trage deinen Anthropic-API-Key ein.
# Key erstellen: https://console.anthropic.com  ->  Settings  ->  API Keys
# Die .env ist per .gitignore ausgeschlossen und wird NICHT hochgeladen.

ANTHROPIC_API_KEY=sk-ant-...

# Optional:
# STOCK_RADAR_LLM_TOPN=60        # wie viele Top-Titel die KI bewertet
# STOCK_RADAR_LLM_MODEL=claude-haiku-4-5
